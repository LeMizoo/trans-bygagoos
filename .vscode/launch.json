{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🐛 Déboguer API NestJS",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:debug"],
      "cwd": "${workspaceFolder}/apps/api",
      "console": "integratedTerminal",
      "restart": true,
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**"],
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "🌐 Déboguer Admin Web",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/apps/admin-web/src",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/*"
      }
    },
    {
      "name": "📱 Déboguer Mobile PWA",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5174",
      "webRoot": "${workspaceFolder}/apps/mobile-pwa/src"
    }
  ],
  "compounds": [
    {
      "name": "🚀 Déboguer Full Stack",
      "configurations": [
        "🐛 Déboguer API NestJS",
        "🌐 Déboguer Admin Web",
        "📱 Déboguer Mobile PWA"
      ]
    }
  ]
}