generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  password      String?
  nom           String?
  prenom        String?
  role          String    @default("CHAUFFEUR")
  statut        String    @default("ACTIF")
  
  // Nouveaux champs pour login mobile
  codeAcces     String?   @unique
  pin           String?
  
  // Relations
  cooperativeId String?
  cooperative   Cooperative? @relation(fields: [cooperativeId], references: [id])
  flotteId      String?
  flotte        Flotte?      @relation(fields: [flotteId], references: [id])
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations avec les entités
  courses       Course[]
  pointages     Pointage[]
  depenses      Depense[]
  versements    Versement[]
  commandes     Commande[]
  logs          Log[]
  notifications Notification[]
  assistances   Assistance[]
}

model Flotte {
  id        String   @id @default(uuid())
  nom       String
  code      String   @unique
  adresse   String?
  telephone String?
  email     String?
  statut    String   @default("ACTIF")
  users     User[]
  motos     Moto[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cooperative {
  id        String   @id @default(uuid())
  nom       String
  code      String   @unique
  adresse   String?
  telephone String?
  email     String?
  statut    String   @default("ACTIF")
  users     User[]
  vehicules Vehicule[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Moto {
  id           String   @id @default(uuid())
  immatriculation String @unique
  marque       String?
  modele       String?
  annee        Int?
  statut       String   @default("ACTIF")
  flotteId     String
  flotte       Flotte   @relation(fields: [flotteId], references: [id])
  courses      Course[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Vehicule {
  id           String   @id @default(uuid())
  immatriculation String @unique
  marque       String?
  modele       String?
  annee        Int?
  statut       String   @default("ACTIF")
  cooperativeId String
  cooperative  Cooperative @relation(fields: [cooperativeId], references: [id])
  commandes    Commande[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Course {
  id        String   @id @default(uuid())
  depart    String
  arrivee   String
  prix      Float
  statut    String   @default("EN_COURS")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  motoId    String?
  moto      Moto?    @relation(fields: [motoId], references: [id])
  dateCourse DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Commande {
  id          String   @id @default(uuid())
  reference   String   @unique
  description String?
  prix        Float
  statut      String   @default("EN_ATTENTE")
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  vehiculeId  String?
  vehicule    Vehicule? @relation(fields: [vehiculeId], references: [id])
  dateLivraison DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pointage {
  id        String   @id @default(uuid())
  type      String   // ENTREE, SORTIE
  date      DateTime
  localisation String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Depense {
  id          String   @id @default(uuid())
  type        String
  montant     Float
  description String?
  date        DateTime
  justificatif String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Versement {
  id        String   @id @default(uuid())
  montant   Float
  mode      String
  reference String?
  date      DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Log {
  id        String   @id @default(uuid())
  action    String
  details   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  titre     String
  message   String
  type      String
  lu        Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Assistance {
  id        String   @id @default(uuid())
  type      String
  message   String
  statut    String   @default("EN_ATTENTE")
  reponse   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Parametre {
  id        String   @id @default(uuid())
  cle       String   @unique
  valeur    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Abonnement {
  id        String   @id @default(uuid())
  type      String
  statut    String
  debut     DateTime
  fin       DateTime?
  flotteId  String?
  cooperativeId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
