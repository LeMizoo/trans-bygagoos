generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  nom       String
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  actif     Boolean  @default(true)
  flotteId  String?
  flotte    Flotte?  @relation(fields: [flotteId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Flotte {
  id             String         @id @default(cuid())
  nom            String
  slug           String         @unique
  description    String?
  logo           String?
  adresse        String?
  telephone      String?
  email          String?
  statut         String         @default("ACTIF")
  abonnement     String         @default("GRATUIT")
  dateFinAbonnement DateTime?
  users          User[]
  motos          Moto[]
  chauffeurs     Chauffeur[]
  courses     Course[]
  depenses    Depense[]
  contrats    Contrat[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Chauffeur {
  id          String       @id @default(cuid())
  nom         String
  telephone   String       @unique
  codeAcces   String       @unique
  pin         String
  statut      String       @default("HORS_SERVICE")
  solde       Float        @default(0)
  actif       Boolean      @default(true)
  motoId      String?      @unique
  moto        Moto?        @relation(fields: [motoId], references: [id])
  flotteId    String?
  flotte      Flotte?      @relation(fields: [flotteId], references: [id])
  courses     Course[]
  pointages   Pointage[]
  versements  Versement[]
  assistance  Assistance[]
  contrats    Contrat[]
  messages    Message[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Moto {
  id                    String       @id @default(cuid())
  immatriculation       String       @unique
  marque                String
  modele                String
  cylindree             String?
  couleur               String?
  kmActuel              Float        @default(0)
  prixAchat             Float?
  dateAchat             DateTime?
  statut                String       @default("disponible")
  proprietaireId        String?
  proprietaire          Proprietaire? @relation(fields: [proprietaireId], references: [id])
  flotteId              String?
  flotte                Flotte?      @relation(fields: [flotteId], references: [id])
  kmProchaineVidange    Float?
  finAssurance          DateTime?
  finVignette           DateTime?
  chauffeur             Chauffeur?
  courses               Course[]
  depenses              Depense[]
  contrats    Contrat[]
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model Proprietaire {
  id        String   @id @default(cuid())
  nom       String
  telephone String   @unique
  email     String?
  cin       String?
  motos     Moto[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id          String    @id @default(cuid())
  chauffeurId String
  chauffeur   Chauffeur @relation(fields: [chauffeurId], references: [id])
  motoId      String
  moto        Moto      @relation(fields: [motoId], references: [id])
  type        String
  distance    Float?
  prix        Float
  commission  Float
  gainNet     Float
  flotteId    String?
  flotte      Flotte?   @relation(fields: [flotteId], references: [id])
  createdAt   DateTime  @default(now())
}

model Pointage {
  id           String    @id @default(cuid())
  chauffeurId  String
  chauffeur    Chauffeur @relation(fields: [chauffeurId], references: [id])
  type         String
  datePointage DateTime  @default(now())
}

model Versement {
  id           String    @id @default(cuid())
  chauffeurId  String
  chauffeur    Chauffeur @relation(fields: [chauffeurId], references: [id])
  montantDu    Float
  montantVerse Float
  statut       String    @default("EN_ATTENTE")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Assistance {
  id          String    @id @default(cuid())
  chauffeurId String
  chauffeur   Chauffeur @relation(fields: [chauffeurId], references: [id])
  type        String
  urgence     String    @default("NORMALE")
  description String
  statut      String    @default("OUVERT")
  createdAt   DateTime  @default(now())
}

model Depense {
  id          String   @id @default(cuid())
  description String
  montant     Float
  categorie   String
  motoId      String?
  moto        Moto?    @relation(fields: [motoId], references: [id])
  litres      Float?
  station     String?
  flotteId    String?
  flotte      Flotte?  @relation(fields: [flotteId], references: [id])
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

model Contrat {
  id          String    @id @default(cuid())
  chauffeurId String
  chauffeur   Chauffeur @relation(fields: [chauffeurId], references: [id])
  motoId      String
  moto        Moto      @relation(fields: [motoId], references: [id])
  type        String
  dateDebut   DateTime
  dateFin     DateTime?
  statut      String    @default("ACTIF")
  flotteId    String?
  flotte      Flotte?   @relation(fields: [flotteId], references: [id])
  createdAt   DateTime  @default(now())
}

model Message {
  id          String    @id @default(cuid())
  contenu     String
  expediteur  String
  chauffeurId String
  chauffeur   Chauffeur @relation(fields: [chauffeurId], references: [id])
  lu          Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model Parametre {
  id          String   @id @default(cuid())
  nom         String   @unique
  valeur      String
  type        String   @default("text")
  description String?
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  titre     String
  message   String
  type      String
  lu        Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())
}
